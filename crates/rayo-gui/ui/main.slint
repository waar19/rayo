import { Button, CheckBox, LineEdit, SpinBox, VerticalBox, HorizontalBox, ScrollView } from "std-widgets.slint";

export struct ResultRow {
    kind: string,
    name: string,
    path: string,
}

export component MainWindow inherits Window {
    title: "Rayo";
    width: 1040px;
    height: 700px;
    background: #111317;
    icon: @image-url("assets/rayo.png");

    in-out property <string> query: "";
    in-out property <string> status-text: "Ready.";
    in-out property <string> mode-text: "service: disconnected";
    in-out property <string> under-text: "<none>";
    in-out property <int> selected-index: -1;
    in-out property <[ResultRow]> results: [];
    in-out property <bool> show-settings: false;
    in-out property <string> settings-under-dir: "";
    in-out property <string> settings-extension: "";
    in-out property <bool> settings-files-only: false;
    in-out property <bool> settings-directories-only: false;
    in-out property <int> settings-limit: 200;
    in-out property <int> settings-debounce-ms: 10;
    in-out property <string> settings-error-text: "";
    in-out property <string> settings-hint: "";
    forward-focus: keyboard-shortcuts;

    callback query-edited(string);
    callback clear-query();
    callback search-now();
    callback open-settings();
    callback save-settings(string, string, bool, bool, int, int);
    callback cancel-settings();
    callback reset-settings();
    callback clear-settings-filters();
    callback select-row(int);
    callback activate-row(int);
    callback open-selected();
    callback open-selected-admin();
    callback open-folder-selected();
    callback copy-path-selected();

    VerticalBox {
        spacing: 10px;
        padding: 12px;

        Rectangle {
            border-color: #2a2f36;
            border-width: 1px;
            border-radius: 8px;
            background: #171a21;

            HorizontalBox {
                padding: 10px;
                spacing: 8px;

                Text {
                    text: "Rayo";
                    color: #d7e0f0;
                    font-size: 20px;
                    font-weight: 600;
                    vertical-alignment: center;
                    horizontal-stretch: 0;
                }

                search-input := LineEdit {
                    text <=> root.query;
                    placeholder-text: "Search files and folders";
                    font-size: 15px;
                    height: 36px;
                    changed text => {
                        root.query-edited(self.text);
                    }
                }

                Button {
                    text: "X";
                    enabled: root.query != "";
                    horizontal-stretch: 0;
                    clicked => { root.clear-query(); }
                }

                Button {
                    text: "Search";
                    horizontal-stretch: 0;
                    clicked => { root.search-now(); }
                }

                Button {
                    text: "Settings";
                    horizontal-stretch: 0;
                    clicked => { root.open-settings(); }
                }

                Text {
                    text: root.mode-text;
                    color: #8fa4bf;
                    vertical-alignment: center;
                    horizontal-stretch: 0;
                }

                Text {
                    text: root.settings-hint;
                    color: #8fa4bf;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }
        }

        Rectangle {
            border-color: #2a2f36;
            border-width: 1px;
            border-radius: 8px;
            background: #111317;
            clip: true;
            vertical-stretch: 1;

            if root.results.length == 0 : Rectangle {
                background: #111317;
                Text {
                    text: root.status-text;
                    color: #8fa4bf;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            if root.results.length > 0 : ScrollView {
                VerticalBox {
                    spacing: 0px;

                    for row[idx] in root.results: Rectangle {
                        height: 48px;
                        background: row-touch.has-hover ? #232a35 : (root.selected-index == idx ? #2d4260 : #111317);

                        HorizontalBox {
                            padding: 8px;
                            spacing: 10px;

                            Text {
                                text: row.kind;
                                color: #8fa4bf;
                                width: 46px;
                                vertical-alignment: center;
                                horizontal-alignment: center;
                            }

                            VerticalBox {
                                spacing: 2px;
                                Text {
                                    text: row.name;
                                    color: #d7e0f0;
                                    font-size: 14px;
                                    vertical-alignment: center;
                                }
                                Text {
                                    text: row.path;
                                    color: #8fa4bf;
                                    font-size: 12px;
                                    overflow: elide;
                                }
                            }
                        }

                        row-touch := TouchArea {
                            clicked => {
                                root.select-row(idx);
                            }
                            double-clicked => {
                                root.activate-row(idx);
                            }
                        }
                    }
                }
            }

            if root.show-settings : Rectangle {
                background: #111317;

                Rectangle {
                    x: 16px;
                    y: 16px;
                    width: parent.width - 32px;
                    height: parent.height - 32px;
                    border-color: #2a2f36;
                    border-width: 1px;
                    border-radius: 8px;
                    background: #171a21;

                    ScrollView {
                        VerticalBox {
                            spacing: 10px;
                            padding: 14px;

                            Text {
                                text: "Settings";
                                color: #d7e0f0;
                                font-size: 18px;
                                font-weight: 600;
                            }

                            Text {
                                text: "Search in folder";
                                color: #8fa4bf;
                                font-size: 12px;
                            }
                            LineEdit {
                                text <=> root.settings-under-dir;
                                placeholder-text: "Example: C:\\src";
                            }

                            Text {
                                text: "Extension filter";
                                color: #8fa4bf;
                                font-size: 12px;
                            }
                            LineEdit {
                                text <=> root.settings-extension;
                                placeholder-text: "Example: pdf";
                            }

                            Text {
                                text: "Tip: Save applies filters immediately to the current search.";
                                color: #8fa4bf;
                                font-size: 12px;
                            }

                            if root.settings-error-text != "" : Text {
                                text: root.settings-error-text;
                                color: #ff6b6b;
                                font-size: 12px;
                            }

                            HorizontalBox {
                                spacing: 14px;
                                CheckBox {
                                    text: "Files only";
                                    checked <=> root.settings-files-only;
                                    toggled => {
                                        if (self.checked) {
                                            root.settings-directories-only = false;
                                        }
                                    }
                                }
                                CheckBox {
                                    text: "Folders only";
                                    checked <=> root.settings-directories-only;
                                    toggled => {
                                        if (self.checked) {
                                            root.settings-files-only = false;
                                        }
                                    }
                                }
                            }

                            Text {
                                text: "Max results";
                                color: #8fa4bf;
                                font-size: 12px;
                            }
                            SpinBox {
                                value <=> root.settings-limit;
                                minimum: 10;
                                maximum: 1000;
                                step-size: 10;
                            }

                            Text {
                                text: "Typing delay (ms)";
                                color: #8fa4bf;
                                font-size: 12px;
                            }
                            SpinBox {
                                value <=> root.settings-debounce-ms;
                                minimum: 0;
                                maximum: 200;
                                step-size: 5;
                            }

                            Rectangle {
                                height: 1px;
                                background: #2a2f36;
                            }

                            HorizontalBox {
                                spacing: 8px;
                                Rectangle { horizontal-stretch: 1; }
                                Button {
                                    text: "Clear filters";
                                    horizontal-stretch: 0;
                                    clicked => { root.clear-settings-filters(); }
                                }
                                Button {
                                    text: "Reset";
                                    horizontal-stretch: 0;
                                    clicked => { root.reset-settings(); }
                                }
                                Button {
                                    text: "Cancel";
                                    horizontal-stretch: 0;
                                    clicked => { root.cancel-settings(); }
                                }
                                Button {
                                    text: "Save";
                                    horizontal-stretch: 0;
                                    clicked => {
                                        root.save-settings(
                                            root.settings-under-dir,
                                            root.settings-extension,
                                            root.settings-files-only,
                                            root.settings-directories-only,
                                            root.settings-limit,
                                            root.settings-debounce-ms
                                        );
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        Rectangle {
            border-color: #2a2f36;
            border-width: 1px;
            border-radius: 8px;
            background: #171a21;

            HorizontalBox {
                padding: 10px;
                spacing: 8px;

                Button {
                    text: "Open";
                    enabled: root.selected-index >= 0;
                    horizontal-stretch: 0;
                    clicked => { root.open-selected(); }
                }
                Button {
                    text: "Open as admin";
                    enabled: root.selected-index >= 0;
                    horizontal-stretch: 0;
                    clicked => { root.open-selected-admin(); }
                }
                Button {
                    text: "Open folder";
                    enabled: root.selected-index >= 0;
                    horizontal-stretch: 0;
                    clicked => { root.open-folder-selected(); }
                }
                Button {
                    text: "Copy path";
                    enabled: root.selected-index >= 0;
                    horizontal-stretch: 0;
                    clicked => { root.copy-path-selected(); }
                }

                Text {
                    text: root.status-text + " | under=" + root.under-text;
                    color: #8fa4bf;
                    font-size: 12px;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }
        }
    }

    keyboard-shortcuts := FocusScope {
        capture-key-pressed(event) => {
            if (event.modifiers.control && event.text == ",") {
                root.open-settings();
                return accept;
            }
            if (event.text == Key.Escape && root.show-settings) {
                root.cancel-settings();
                return accept;
            }
            return reject;
        }
    }
}
