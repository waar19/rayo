import { Button, LineEdit, VerticalBox, HorizontalBox, ScrollView } from "std-widgets.slint";

export struct ResultRow {
    kind: string,
    name: string,
    path: string,
}

export component MainWindow inherits Window {
    title: "Rayo";
    width: 1040px;
    height: 700px;
    background: #111317;

    in-out property <string> query: "";
    in-out property <string> status-text: "Ready.";
    in-out property <string> mode-text: "service: disconnected";
    in-out property <string> under-text: "<none>";
    in-out property <int> selected-index: -1;
    in-out property <[ResultRow]> results: [];

    callback query-edited(string);
    callback search-now();
    callback select-row(int);
    callback activate-row(int);
    callback open-selected();
    callback open-selected-admin();
    callback open-folder-selected();
    callback copy-path-selected();

    VerticalBox {
        spacing: 10px;
        padding: 12px;

        Rectangle {
            border-color: #2a2f36;
            border-width: 1px;
            border-radius: 8px;
            background: #171a21;

            HorizontalBox {
                padding: 10px;
                spacing: 8px;

                Text {
                    text: "Rayo";
                    color: #d7e0f0;
                    font-size: 20px;
                    font-weight: 600;
                    vertical-alignment: center;
                    horizontal-stretch: 0;
                }

                search-input := LineEdit {
                    text <=> root.query;
                    placeholder-text: "Search files and folders";
                    font-size: 15px;
                    height: 36px;
                    edited => {
                        root.query-edited(self.text);
                    }
                }

                Button {
                    text: "Search";
                    horizontal-stretch: 0;
                    clicked => { root.search-now(); }
                }

                Text {
                    text: root.mode-text;
                    color: #8fa4bf;
                    vertical-alignment: center;
                    horizontal-stretch: 0;
                }
            }
        }

        Rectangle {
            border-color: #2a2f36;
            border-width: 1px;
            border-radius: 8px;
            background: #111317;
            clip: true;
            vertical-stretch: 1;

            if root.results.length == 0 : Rectangle {
                background: #111317;
                Text {
                    text: root.status-text;
                    color: #8fa4bf;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            if root.results.length > 0 : ScrollView {
                VerticalBox {
                    spacing: 0px;

                    for row[idx] in root.results: Rectangle {
                        height: 48px;
                        background: row-touch.has-hover ? #232a35 : (root.selected-index == idx ? #2d4260 : #111317);

                        HorizontalBox {
                            padding: 8px;
                            spacing: 10px;

                            Text {
                                text: row.kind;
                                color: #8fa4bf;
                                width: 46px;
                                vertical-alignment: center;
                                horizontal-alignment: center;
                            }

                            VerticalBox {
                                spacing: 2px;
                                Text {
                                    text: row.name;
                                    color: #d7e0f0;
                                    font-size: 14px;
                                    vertical-alignment: center;
                                }
                                Text {
                                    text: row.path;
                                    color: #8fa4bf;
                                    font-size: 12px;
                                    overflow: elide;
                                }
                            }
                        }

                        row-touch := TouchArea {
                            clicked => {
                                root.select-row(idx);
                            }
                            double-clicked => {
                                root.activate-row(idx);
                            }
                        }
                    }
                }
            }
        }

        Rectangle {
            border-color: #2a2f36;
            border-width: 1px;
            border-radius: 8px;
            background: #171a21;

            HorizontalBox {
                padding: 10px;
                spacing: 8px;

                Button {
                    text: "Open";
                    enabled: root.selected-index >= 0;
                    horizontal-stretch: 0;
                    clicked => { root.open-selected(); }
                }
                Button {
                    text: "Open as admin";
                    enabled: root.selected-index >= 0;
                    horizontal-stretch: 0;
                    clicked => { root.open-selected-admin(); }
                }
                Button {
                    text: "Open folder";
                    enabled: root.selected-index >= 0;
                    horizontal-stretch: 0;
                    clicked => { root.open-folder-selected(); }
                }
                Button {
                    text: "Copy path";
                    enabled: root.selected-index >= 0;
                    horizontal-stretch: 0;
                    clicked => { root.copy-path-selected(); }
                }

                Text {
                    text: root.status-text + " | under=" + root.under-text;
                    color: #8fa4bf;
                    font-size: 12px;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }
        }
    }
}
